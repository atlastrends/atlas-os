# ============================================================
# ATLAS OS - .env.example
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA coloque segredos reais neste arquivo (.env.example).
# ============================================================

# --- Aplicação ---
APP_NAME=AtlasOS
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=America/Sao_Paulo

# --- PostgreSQL ---
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=atlas_os
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# String de conexão (montada a partir das variáveis acima)
DATABASE_URL=postgresql+asyncpg://atlas:change_me_strong_password@postgres:5432/atlas_os
DATABASE_URL_SYNC=postgresql+psycopg2://atlas:change_me_strong_password@postgres:5432/atlas_os

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --- Celery (Core Engine) ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Segurança ---
SECRET_KEY=change_me_generate_a_random_secret_key

# ============================================================
# INTEGRAÇÕES DE PLATAFORMAS (preencher nas Fases 6+)
# Uso restrito às APIs OFICIAIS, em conformidade com os ToS.
# ============================================================

# --- YouTube Data API ---
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# Opcionais: privacidade do upload e coleta de metricas do canal.
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CHANNEL_ID=

# --- Meta (Instagram / Facebook Graph API) ---
# Um unico token (META_ACCESS_TOKEN) atende todas as contas abaixo.
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v21.0
# Fallback antigo (opcional) - conta unica quando nao usar o roteamento abaixo:
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# ROTEAMENTO DAS CONTAS (por tipo de video x mercado)
#   AFFILIATE = videos de produtos (Achados / Finds)
#   TREND     = reels de tendencias
#   BR = Brasil   |   US = Estados Unidos
# Afiliados BR:
FB_PAGE_AFFILIATE_BR=
IG_AFFILIATE_BR=
# Afiliados US:
FB_PAGE_AFFILIATE_US=
IG_AFFILIATE_US=
# Trends/Reels BR:
FB_PAGE_TREND_BR=
IG_TREND_BR=
# Trends/Reels US:
FB_PAGE_TREND_US=
IG_TREND_US=

# --- TikTok Content Posting API ---
# Um app do TikTok Developers (Content Posting API).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Endereco de retorno FIXO (pagina no GitHub Pages que reenvia o login para o
# ATLAS local). Cadastre o MESMO endereco no painel do TikTok (Redirect URI).
ATLAS_TIKTOK_REDIRECT_URI=https://atlastrends.github.io/atlas-os/tiktok/
# Token por mercado (recomendado): PT -> conta BR, EN -> conta US.
TIKTOK_ACCESS_TOKEN_BR=
TIKTOK_ACCESS_TOKEN_US=
# Alternativa: token unico, se voce tiver UMA conta so (serve para BR e US):
TIKTOK_ACCESS_TOKEN=
# SELF_ONLY (privado, sandbox) ou PUBLIC_TO_EVERYONE (app aprovado).
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
# Permissoes pedidas no login do TikTok. Inclui leitura de metricas
# (user.info.stats = seguidores/curtidas, video.list = views por video).
TIKTOK_SCOPES=user.info.basic,user.info.profile,user.info.stats,video.upload,video.publish,video.list
# "Post direto" (publica sozinho no perfil, com legenda e link). So funciona
# depois que o app for APROVADO pelo TikTok. Enquanto estiver "em revisao",
# deixe false: o ATLAS envia como rascunho e voce finaliza no app do TikTok.
TIKTOK_DIRECT_POST=false

# --- Provedores de IA (Fases 4/5) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================================
# PAINEL / LINKS CLICAVEIS
# ============================================================
# URL publica que a Meta/plataformas usam para acessar os videos e os links
# curtos clicaveis (/go/{code}). Em producao use um dominio HTTPS acessivel.
ATLAS_PUBLIC_BASE_URL=http://localhost:8000

# Liga o motor de reels automaticos (1 PT + 1 EN a cada 15 min).
ATLAS_ENGINE_ENABLED=false

# --- Agendador de tarefas automaticas ---
# Coleta de metricas e (opcional) scraper rodando em background.
ATLAS_SCHEDULER_ENABLED=true
ATLAS_METRICS_INTERVAL_HOURS=1
# 0 = desativado. Cuidado: intervalos muito curtos podem levar a bloqueios.
ATLAS_SCRAPER_INTERVAL_HOURS=0

# --- Aprovacao automatica por qualidade ---
# Se ativado, aprova e publica sozinho os videos com qualidade >= min score.
ATLAS_AUTO_APPROVE_ENABLED=false
ATLAS_AUTO_APPROVE_MIN_SCORE=70
ATLAS_AUTO_APPROVE_INTERVAL_HOURS=1
ATLAS_AUTO_APPROVE_KINDS=reel,affiliate

# --- Busca Amazon -> reels imediatos (sem aprovacao manual) ---
# Ao clicar "Buscar produtos Amazon", alem de buscar os produtos,
# gera os reels de afiliado na hora e ja aprova automaticamente.
ATLAS_FETCH_THEN_GENERATE=true
# Quantidade de reels de afiliado gerados por busca.
ATLAS_AFFILIATE_VIDEOS_PER_RUN=5

# --- Tamanho do texto nos reels (legenda/hook) ---
# Renderizado com Pillow (sem ImageMagick). O tamanho se ajusta sozinho
# para nao estourar a largura; estes sao os valores maximos.
ATLAS_SUBTITLE_FONT_SIZE=56
ATLAS_HOOK_FONT_SIZE=58
# Opcional: caminho de uma fonte .ttf especifica.
# ATLAS_FONT_PATH=C:\Windows\Fonts\segoeuib.ttf
# --- Geracao de roteiro pela IA ---
# Teto de tokens da resposta da IA. Precisa ser alto o suficiente para os
# modelos de raciocinio (gpt-oss) "pensarem" E ainda escreverem o roteiro;
# se for baixo, o texto final volta VAZIO (0 palavras).
ATLAS_AI_MAX_TOKENS=1600

# ============================================================
# ATUALIZACAO AUTOMATICA (botao "Procurar atualizacoes")
# ============================================================
# Endereco do repositorio PUBLICO no GitHub onde fica o codigo do ATLAS.
# Formato: usuario/nome-do-repositorio  (ex.: cpenteri/atlas-os)
# Deixe vazio para desligar as atualizacoes.
ATLAS_UPDATE_REPO=
# Ramo (branch) de onde baixar. Normalmente "main".
ATLAS_UPDATE_BRANCH=main


